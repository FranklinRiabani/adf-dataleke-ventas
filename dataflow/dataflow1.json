{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Excel1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_plata_inventario_limpio_parquet",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          codigo_producto as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          precio_venta as string,",
				"          costo_adquisicion as string,",
				"          stock_actual as string,",
				"          stock_minimo as string,",
				"          sucursal as string,",
				"          proveedor as string,",
				"          ultima_reposicion as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          codigo_producto,",
				"          nombre_producto,",
				"          categoria,",
				"          precio_venta,",
				"          costo_adquisicion,",
				"          stock_actual,",
				"          stock_minimo,",
				"          sucursal,",
				"          proveedor,",
				"          ultima_reposicion,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     partitionFileNames:['inventarioLimpio'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}