					{
						"name": "stock_actual",
						"type": "String"
					},
					{
						"name": "stock_minimo",
						"type": "String"
					},
					{
						"name": "sucursal",
						"type": "String"
					},
					{
						"name": "proveedor",
						"type": "String"
					},
					{
						"name": "ultima_reposicion",
						"type": "String"
