			"name": "[concat(parameters('factoryName'), '/Excel1')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "AzureBlobStorage1",
					"type": "LinkedServiceReference"
				},
				"folder": {
					"name": "bronze2"
				},
				"annotations": [],
				"type": "Excel",
				"typeProperties": {
					"sheetName": "Sheet1",
					"location": {
						"type": "AzureBlobStorageLocation",
						"fileName": "inventario.xlsx",
						"folderPath": "bronze",
						"container": "dw-ventas"
					},
					"firstRowAsHeader": true
				},
				"schema": [
					{
						"name": "codigo_producto",
						"type": "String"
					},
					{
						"name": "nombre_producto",
						"type": "String"
					},
					{
						"name": "categoria",
						"type": "String"
					},
					{
						"name": "precio_venta",
						"type": "String"
					},
					{
						"name": "costo_adquisicion",
						"type": "String"
					},
					{
						"name": "stock_actual",
						"type": "String"
					},
					{
						"name": "stock_minimo",
						"type": "String"
					},
					{
						"name": "sucursal",
						"type": "String"
					},
					{
						"name": "proveedor",
						"type": "String"
					},
					{
						"name": "ultima_reposicion",
						"type": "String"
					},
					{
						"name": "activo",
						"type": "String"
					}
				]
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/AzureBlobStorage1')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/ds_plata_inventario_limpio_parquet')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "AzureDataLakeStorage1",
					"type": "LinkedServiceReference"
				},
				"folder": {
					"name": "silver"
				},
				"annotations": [],
				"type": "Parquet",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": "silver",
						"fileSystem": "dw-ventas"
					},
					"compressionCodec": "snappy"
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/AzureDataLakeStorage1')]"
			]
		},
